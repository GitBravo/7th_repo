# 이 파일을 복사해서 ".env"라는 이름으로 저장한 뒤, 아래 값들을 실제 발급받은 키로 채워주세요.
# .env 파일은 git에 올라가지 않도록 이미 설정되어 있습니다 (.gitignore 참고).

# Supabase (벡터 데이터베이스) - https://supabase.com 에서 프로젝트 생성 후 발급
SUPABASE_URL=
SUPABASE_KEY=

# OpenAI (문서 임베딩 전용) - https://platform.openai.com
OPENAI_API_KEY=

# OpenRouter (답변 생성 채팅 모델) - https://openrouter.ai
OPENROUTER_API_KEY=

# Cohere (검색 결과 재정렬, Rerank) - https://dashboard.cohere.com
COHERE_API_KEY=
